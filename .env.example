# MongoDB Connection
MONGODB_URI=

# JWT Secret for Custom Auth (Mobile)
JWT_SECRET=           # Minimum 64-character random string recommended

# Admin Override Access
MASTER_PASSWORD=      # Secure admin bypass password

# Clerk Authentication (Web/General)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Email Services (Transactional Notifications)
RESEND_API_KEY=

# Image Storage (Cloudinary Asset Management)
CLOUDINARY_CLOUD_NAME=

# LiveKit (Real-time Video/Audio)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Firebase Admin (Push Notifications)
FIREBASE_SERVICE_ACCOUNT=  # Base64 or stringified JSON of your private key service account

# WebSocket (Real-time Messaging)
NEXT_PUBLIC_WS_URL=        # wss://your-message-server.com
