{
  "name": "tibetan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build:rust": "./build-rust.sh",
    "build": "next build --webpack",
    "ionic:build": "CAPACITOR_BUILD=true next build --webpack",
    "build:mobile": "CAPACITOR_BUILD=true next build && npx cap sync",
    "build:android": "npm run build:mobile && npx cap build android",
    "build:ios": "npm run build:mobile && npx cap build ios",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx database/seed.ts",
    "db:indexes": "node scripts/create-indexes.js",
    "perf:stats": "curl http://localhost:3000/api/performance/stats | json_pp",
    "cache:clear": "curl -X POST http://localhost:3000/api/performance/stats?action=clearCache",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "mobile:update": "npm run build:mobile && npx cap copy && npx cap update",
    "mobile:clean": "rm -rf android/app/build ios/App/build",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@clerk/nextjs": "^6.36.5",
    "@livekit/components-react": "^2.9.17",
    "@livekit/components-styles": "^1.2.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "jose": "^6.1.3",
    "lenis": "^1.3.17",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.562.0",
    "mongodb": "^7.0.0",
    "next": "16.1.1",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.12",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.6.0",
    "rust-modules": "file:rust-modules/pkg",
    "svix": "^1.82.0"
  },
  "devDependencies": {
    "@capacitor/network": "^8.0.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@wdio/cli": "^9.23.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "webdriverio": "^9.23.3"
  }
}
